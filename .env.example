# =========================================
# Narrative Radar v2 - Environment Variables
# =========================================

# === Telegram (必填) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_chat_id

# === AI Providers (至少配一个，越多 fallback 越强) ===

# --- 中转站 / Relay Station (推荐放第一位) ---
# 如果你有 one-api / new-api / chat-next-web 等中转站：
# RELAY_API_KEY=sk-your-relay-key
# RELAY_BACKUP_KEY=sk-your-backup-relay-key

# --- Groq (免费, 14400请求/天, 30 RPM) ---
GROQ_API_KEY=gsk_your_groq_key

# --- DeepSeek (极便宜, $0.14/M tokens) ---
DEEPSEEK_API_KEY=sk-your_deepseek_key

# --- Google Gemini (免费层, 1000请求/天) ---
GEMINI_API_KEY=your_gemini_key

# --- OpenRouter (聚合100+模型, 按量付费) ---
# OPENROUTER_API_KEY=sk-or-your_key

# --- SiliconFlow (国内快速, 支持多模型) ---
# SILICONFLOW_API_KEY=sk-your_siliconflow_key

# --- OpenAI 官方 ---
# OPENAI_API_KEY=sk-your_openai_key

# --- Together AI ---
# TOGETHER_API_KEY=your_together_key

# --- Fireworks AI ---
# FIREWORKS_API_KEY=your_fireworks_key
