# =========================================
# Narrative Radar v2 - Environment Variables
# =========================================

# === Telegram (至少配一个推送渠道) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_chat_id
# Comma-separated Telegram user IDs allowed to execute bot commands (empty = no restriction)
# TG_ADMIN_IDS=123456789,987654321

# === Feishu 飞书 (可选，与 Telegram 可同时使用) ===
# 在飞书群中添加"自定义机器人"，获取 webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
# 如果开启了签名校验，填写密钥
# FEISHU_WEBHOOK_SECRET=your_secret

# === AI Providers (至少配一个，越多 fallback 越强) ===

# --- 中转站 / Relay Station (推荐放第一位) ---
# 如果你有 one-api / new-api / chat-next-web 等中转站：
# RELAY_API_KEY=sk-your-relay-key
# RELAY_BACKUP_KEY=sk-your-backup-relay-key

# --- Groq (免费, 14400请求/天, 30 RPM) ---
GROQ_API_KEY=gsk_your_groq_key

# --- DeepSeek (极便宜, $0.14/M tokens) ---
DEEPSEEK_API_KEY=sk-your_deepseek_key

# --- Google Gemini (免费层, 1000请求/天) ---
GEMINI_API_KEY=your_gemini_key

# --- OpenRouter (聚合100+模型, 按量付费) ---
# OPENROUTER_API_KEY=sk-or-your_key

# --- SiliconFlow (国内快速, 支持多模型) ---
# SILICONFLOW_API_KEY=sk-your_siliconflow_key

# --- OpenAI 官方 ---
# OPENAI_API_KEY=sk-your_openai_key

# --- Together AI ---
# TOGETHER_API_KEY=your_together_key

# --- Fireworks AI ---
# FIREWORKS_API_KEY=your_fireworks_key


# === Proxy 代理配置 (当 VPS IP 被 GMGN 等数据源封禁时使用) ===
# 支持 http/https/socks5 代理
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:1080

# 指定哪些域名走代理 (逗号分隔)，不设置则所有请求都走代理
# PROXY_DOMAINS=gmgn.ai,dexscreener.com

# === GMGN 自定义地址 (推荐用 Cloudflare Worker 中转) ===
# 部署 CF Worker 后填入你的 Worker 地址，即可绕过 IP 封禁
# GMGN_BASE_URL=https://gmgn-proxy.你的用户名.workers.dev
